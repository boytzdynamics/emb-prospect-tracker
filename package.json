{
  "name": "emb-prospect-tracker",
  "version": "2.2.0",
  "description": "Eugene Mortgage Brokers Prospect Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build-mac": "electron-builder build --mac",
    "build-win": "electron-builder build --win --x64",
    "build-all": "npm run build-mac && npm run build-win"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "electron-updater": "^6.8.3",
    "imap": "^0.8.19",
    "mailparser": "^3.6.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.eugenemb.tracker",
    "productName": "EMB Prospect Tracker",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "icon": "assets/icon.icns"
    },
    "dmg": {
      "title": "EMB Prospect Tracker",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EMB Prospect Tracker",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "boytzdynamics",
        "repo": "emb-prospect-tracker"
      }
    ],
    "files": [
      "**/*",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
